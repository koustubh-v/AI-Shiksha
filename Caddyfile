{
	# Global configuration
	on_demand_tls {
		# Endpoint in the NestJS Backend to verify if the custom domain is registered/allowed
		ask http://127.0.0.1:3000/franchises/verify-domain
	}
}

# 1. Main Application Block (SuperAdmin Domain)
iconsafetyinstitute.com, www.iconsafetyinstitute.com {
	# Reverse proxy API requests to the NestJS Backend running on port 3000
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}
	
	# Handles uploaded files if served via the backend 
	handle /uploads/* {
		reverse_proxy 127.0.0.1:3000
	}

	# Sitemap - dynamically generated by backend
	handle /sitemap.xml {
		reverse_proxy 127.0.0.1:3000 {
			header_up Host {host}
		}
	}

	# Social Media Bot Proxy (WhatsApp, Facebook, Twitter, etc.)
	@socialbot header_regexp User-Agent "facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Pinterest|SkypeUriPreview|TelegramBot|Discordbot|Slackbot"
	handle @socialbot {
		reverse_proxy 127.0.0.1:3000 {
			header_up Host {host}
			header_up X-Original-URI {uri}
		}
	}

	# Serve Frontend Static files from the Vite build output
	handle {
		root * /var/www/lms/Frontend/dist
		
		# Fallback for React Router (SPA)
		try_files {path} /index.html
		file_server
	}
}

# 2. Main API Block
api.iconsafetyinstitute.com {
	reverse_proxy 127.0.0.1:3000 {
		header_up Host {upstream_hostport}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-Port {server_port}
		header_up X-Forwarded-Proto {scheme}
	}
}

# 3. Franchise Domains Block (On-Demand TLS via Wildcard)
https:// {
	tls {
		on_demand
	}

	# Reverse proxy API requests to the NestJS Backend running on port 3000
	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}
	
	# Handles uploaded files if served via the backend 
	handle /uploads/* {
		reverse_proxy 127.0.0.1:3000
	}

	# Sitemap - dynamically generated by backend
	handle /sitemap.xml {
		reverse_proxy 127.0.0.1:3000 {
			header_up Host {host}
		}
	}

	# Social Media Bot Proxy (WhatsApp, Facebook, Twitter, etc.)
	@socialbot header_regexp User-Agent "facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Pinterest|SkypeUriPreview|TelegramBot|Discordbot|Slackbot"
	handle @socialbot {
		reverse_proxy 127.0.0.1:3000 {
			header_up Host {host}
			header_up X-Original-URI {uri}
		}
	}

	# Serve Frontend Static files from the Vite build output
	handle {
		root * /var/www/lms/Frontend/dist
		
		# Fallback for React Router (SPA)
		try_files {path} /index.html
		file_server
	}
}
